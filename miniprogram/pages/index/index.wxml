<wxs module="utils" src="../../utils/tileDisplay.wxs"></wxs>

<view class="container">

    <view class="tile-selection">
        <view class="tile-row">
            <view wx:for="{{['w1','w2','w3','w4','w5','w6','w7','w8','w9']}}" wx:key="*this" 
                  class="tile-btn {{concealedTiles.indexOf(item) > -1 ? 'selected' : ''}}"
                  data-tile="{{item}}" bindtap="toggleTile">
                {{utils.getTileDisplay(item)}}
            </view>
        </view>

        <view class="tile-row">
            <view wx:for="{{['t1','t2','t3','t4','t5','t6','t7','t8','t9']}}" wx:key="*this" 
                  class="tile-btn {{concealedTiles.indexOf(item) > -1 ? 'selected' : ''}}"
                  data-tile="{{item}}" bindtap="toggleTile">
                {{utils.getTileDisplay(item)}}
            </view>
        </view>

        <view class="tile-row">
            <view wx:for="{{['b1','b2','b3','b4','b5','b6','b7','b8','b9']}}" wx:key="*this" 
                  class="tile-btn {{concealedTiles.indexOf(item) > -1 ? 'selected' : ''}}"
                  data-tile="{{item}}" bindtap="toggleTile">
                {{utils.getTileDisplay(item)}}
            </view>
        </view>

        <view class="tile-row">
            <view wx:for="{{['east','south','west','north','zhong','fa','bai']}}" wx:key="*this" 
                  class="tile-btn {{concealedTiles.indexOf(item) > -1 ? 'selected' : ''}}"
                  data-tile="{{item}}" bindtap="toggleTile">
                {{utils.getTileDisplay(item)}}
            </view>
        </view>
    </view>

    <view class="options-section">
        <view class="mode-selector">
            <view wx:for="{{['concealed','pong','chi','minggang','angang']}}" wx:key="*this" 
                  class="mode-btn {{currentMode === item ? 'active' : ''}}"
                  data-mode="{{item}}" bindtap="setMode">
                {{utils.getModeText(item)}}
            </view>
            <view class="reset-btn" bindtap="resetAll">重置</view>
        </view>

        <view class="wind-selector">
            <view class="wind-group">
                <text class="label">门风</text>
                <view class="wind-btns">
                    <view wx:for="{{['east','south','west','north']}}" wx:key="*this"
                          class="wind-btn {{options.seatWind === item ? 'active' : ''}}"
                          data-wind="{{item}}" bindtap="setSeatWind">
                        {{utils.getWindText(item)}}
                    </view>
                </view>
            </view>

            <view class="wind-group">
                <text class="label">圈风</text>
                <view class="wind-btns">
                    <view wx:for="{{['east','south','west','north']}}" wx:key="*this"
                          class="wind-btn {{options.prevalentWind === item ? 'active' : ''}}"
                          data-wind="{{item}}" bindtap="setPrevalentWind">
                        {{utils.getWindText(item)}}
                    </view>
                </view>
            </view>
        </view>

        <view class="flower-count">
            <text class="label">花牌数量</text>
            <view class="flower-controls">
                <view class="flower-btn" data-type="decrease" bindtap="setFlowerCount">-</view>
                <text class="flower-value">{{options.flowerCount}}</text>
                <view class="flower-btn" data-type="increase" bindtap="setFlowerCount">+</view>
            </view>
        </view>

        <view class="check-options">
            <view class="check-item">
                <checkbox checked="{{options.isSelfDrawn}}" bindtap="setOption" data-key="isSelfDrawn" />
                <text class="check-label">自摸</text>
            </view>

            <view class="check-item">
                <checkbox checked="{{options.isJuezhang}}" bindtap="setOption" data-key="isJuezhang" />
                <text class="check-label">和绝张</text>
            </view>

            <view wx:if="{{options.isSelfDrawn}}" class="check-item">
                <checkbox checked="{{options.isMiaoshou}}" bindtap="setOption" data-key="isMiaoshou" />
                <text class="check-label">妙手回春</text>
            </view>

            <view wx:if="{{options.isSelfDrawn}}" class="check-item">
                <checkbox checked="{{options.isGangshang}}" bindtap="setOption" data-key="isGangshang" />
                <text class="check-label">杠上开花</text>
            </view>

            <view wx:if="{{!options.isSelfDrawn}}" class="check-item">
                <checkbox checked="{{options.isHaidilao}}" bindtap="setOption" data-key="isHaidilao" />
                <text class="check-label">海底捞月</text>
            </view>

            <view wx:if="{{!options.isSelfDrawn}}" class="check-item">
                <checkbox checked="{{options.isQianggang}}" bindtap="setOption" data-key="isQianggang" />
                <text class="check-label">抢杠和</text>
            </view>
        </view>
    </view>

    <view class="selected-tiles">
        <view class="remaining-tips" wx:if="{{14 - concealedTiles.length - meldGroups.length * 3 - 1 > 0}}">
            还可选择 {{14 - concealedTiles.length - meldGroups.length * 3 - 1}} 张牌
        </view>

        <view class="concealed-section" wx:if="{{concealedTiles.length > 0}}">
            <view wx:for="{{concealedTiles}}" wx:key="index" class="concealed-tile" 
                  data-tile="{{item}}" data-area="concealed" bindtap="removeTile">
                {{utils.getTileDisplay(item)}}
            </view>
        </view>

        <view class="melds-section" wx:if="{{meldGroups.length > 0}}">
            <view wx:for="{{meldGroups}}" wx:key="index" class="meld-group" 
                  data-tile="{{item.tiles[0]}}" data-area="meld" bindtap="removeTile">
                <view wx:for="{{item.tiles}}" wx:for-item="tile" wx:key="*this" 
                      class="meld-tile {{item.type === 'angang' ? 'angang' : ''}}">
                    {{utils.getTileDisplay(tile)}}
                </view>
                <view class="meld-type">{{utils.getMeldTypeText(item.type)}}</view>
            </view>
        </view>
    </view>

    <view class="waiting-section" wx:if="{{waitingTiles.length > 0 && !winTile}}">
        <view class="section-title">听牌</view>
        <view class="waiting-list">
            <view wx:for="{{waitingTiles}}" wx:key="tileId" class="waiting-item" 
                  data-tile="{{item}}" bindtap="updateWinTile">
                <view class="waiting-tile">{{utils.getTileDisplay(item.tileId)}}</view>
                <view class="waiting-info">
                    <view class="tile-name">{{item.tile.name}}</view>
                    <view class="tile-fan">{{item.totalScore}}番</view>
                </view>
            </view>
        </view>
    </view>

    <view class="win-section" wx:if="{{selectedWinTile}}" bindtap="clearWinTile">
        <view class="section-title">和牌（点击取消）</view>
        <view class="win-content">
            <view class="win-tile">{{utils.getTileDisplay(selectedWinTile.tileId)}}</view>
            <view class="win-fan">{{selectedWinTile.totalScore}}番</view>
        </view>
        <view class="fans-list">
            <view wx:for="{{selectedWinTile.fans}}" wx:key="name" class="fan-item">
                {{item.name}} {{item.score}}番
            </view>
        </view>
    </view>
</view>
